TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# Keep model configurable so you can switch without code changes.
OPENAI_MODEL=gpt-5
OPENAI_TIMEOUT_SECONDS=240

# Optional. Leave empty unless you want to cap long answers.
OPENAI_MAX_OUTPUT_TOKENS=

# Comma-separated Telegram numeric user IDs. Leave empty only for local testing.
TELEGRAM_ALLOWED_USER_IDS=

# Optional. Directory for runtime data.
BOT_DATA_DIR=.data

# If true, researcher may use OpenAI's hosted web-search tool.
ENABLE_WEB_SEARCH=true
